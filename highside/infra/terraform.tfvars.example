# Example terraform.tfvars for high-side (air-gapped) environment
# Copy to terraform.tfvars and customize for your deployment

# Azure Government environment
# - usgovernment:         Azure Government IL4/IL5 (*.usgovcloudapi.net)
# - usgovernmentsecret:   Azure Government Secret IL6 (air-gapped)
# - usgovernmenttopsecret: Azure Government Top Secret (air-gapped)
azure_government_environment = "usgovernment"

# Environment configuration
environment = "dev"
location    = "usgovvirginia"
owner       = "your-team-or-name"

# Compliance tags
classification = "CUI"
compliance     = "IL5"

# VM configuration
aptly_vm_size        = "Standard_D4s_v5"
aptly_admin_username = "aptlyadmin"

# SSH public key for VM access (replace with your actual public key)
admin_ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAACAQ... user@host"

# Network configuration (defaults are usually fine)
# vnet_address_space               = ["10.1.0.0/16"]
# aptly_subnet_address_prefix      = "10.1.1.0/24"
# privatelink_subnet_address_prefix = "10.1.2.0/24"

# Internal DNS configuration
internal_dns_suffix = "apt.internal.local"

# Feature flags
enable_blob_storage           = false # Set to true for Phase 2 (Blob storage)
aptly_pool_container_name     = "aptly-pool"
enable_customer_managed_keys  = true  # Enable CMK for encryption at rest
enable_internal_load_balancer = false # Set to true for HA deployment

# Client access control
# List of CIDR blocks for APT clients allowed to access the repo
# allowed_client_subnets = ["10.2.0.0/16", "10.3.0.0/16"]
